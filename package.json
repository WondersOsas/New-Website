{
  "name": "trewjewel-website",
  "version": "1.0.0",
  "description": "TrewJewel Bridal Store - E-commerce website with Hono backend + HTTPS",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:http": "node hono.js",
    "generate-certs": "openssl req -x509 -newkey rsa:2048 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes -subj \"/CN=localhost\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WondersOsas/New-Website.git"
  },
  "keywords": [
    "bridal",
    "ecommerce",
    "trewjewel"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/WondersOsas/New-Website/issues"
  },
  "homepage": "https://github.com/WondersOsas/New-Website#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "hono": "^4.12.31"
  }
}
